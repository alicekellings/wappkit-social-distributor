WORDPRESS_PUBLISH_STATUS=draft
WORDPRESS_REQUIRE_LLM_FOR_PUBLICATION=1
WORDPRESS_DEFAULT_TAGS=wappkit,blog,software
WORDPRESS_DEFAULT_CATEGORIES=Wappkit

