BLOGGER_PUBLISH_STATUS=draft
BLOGGER_REQUIRE_LLM_FOR_PUBLICATION=1
BLOGGER_DEFAULT_LABELS=wappkit,blog,software

WORDPRESS_ACCESS_TOKEN=
WORDPRESS_ACCESS_TOKEN_B64=
