WAPPKIT_SITE_URL=https://www.wappkit.com
WAPPKIT_SITEMAP_URL=https://www.wappkit.com/sitemap.xml
WAPPKIT_RSS_URL=https://www.wappkit.com/rss.xml
WAPPKIT_CONTENT_RAW_BASE_URL=https://raw.githubusercontent.com/alicekellings/wappkit-web/main/content/blog

DATA_DIR=./data
OUTPUTS_DIR=./outputs
CHECK_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_RUN=1
REQUEST_TIMEOUT_SECONDS=30
DELIVERY_PLATFORMS=devto

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4
USE_PUBLIC_API_POOL=0
PUBLIC_API_LIST_FILE=
PUBLIC_API_LIST_URL=
PUBLIC_API_LIST_TEXT=
PUBLIC_API_PROBE_TIMEOUT=15
PUBLIC_API_PROBE_WORKERS=6
PUBLIC_API_PROBE_PROMPT=Reply in one short English sentence that confirms you can rewrite a blog post.
PUBLIC_API_CACHE_TTL_MINUTES=30

MODEL_POOL_CONFIG_FILE=
MODEL_POOL_CONFIG_URL=
MODEL_POOL_CONFIG_JSON=
FALLBACK_GROQ_API_KEY=
FALLBACK_GROQ_BASE_URL=https://api.groq.com/openai/v1
FALLBACK_GROQ_MODELS=openai/gpt-oss-120b,openai/gpt-oss-20b
FALLBACK_NVIDIA_API_KEY=
FALLBACK_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
FALLBACK_NVIDIA_MODELS=mistralai/mistral-small-3.1-24b-instruct,google/gemma-3-27b-it
FALLBACK_CLOUDFLARE_API_KEY=
FALLBACK_CLOUDFLARE_ACCOUNT_ID=
FALLBACK_CLOUDFLARE_MODELS=@cf/openai/gpt-oss-120b,@cf/meta/llama-3.3-70b-instruct-fp8-fast

DEVTO_API_KEY=
DEVTO_PUBLISH_STATUS=draft
DEVTO_REQUIRE_LLM_FOR_PUBLICATION=1
DEVTO_DEFAULT_TAGS=wappkit,software,productivity,saas

BLOGGER_ACCESS_TOKEN=
BLOGGER_BLOG_ID=
